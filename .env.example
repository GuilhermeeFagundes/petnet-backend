# ─────────────────────────────────────────────
# Banco de Dados
# ─────────────────────────────────────────────
DATABASE_URL="mysql://root:password@localhost:5678/netcao_development"

# ─────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────
# JWT - Autenticação
# Para gerar um segredo seguro, rode no terminal:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────
JWT_SECRET="your-super-secret-key-change-this-in-production"
JWT_EXPIRES_IN="1d"

#-------------------------------------
# Configurações do Admin TI (Seed)
#-------------------------------------
ADMIN_CPF="00000000000"
ADMIN_NAME="Admin TI"
ADMIN_EMAIL="admin@petnet.com.br"
ADMIN_PASSWORD="mudar-isso-em-producao"

#-------------------------------------
# Recuperação de senha
# https://resend.com
#-------------------------------------
RESEND_API_KEY=api-key-gerada-automaticamente
RESEND_FROM_EMAIL=nao-responda@petnet.com.br
FRONTEND_URL=http://localhost:5173
#-------------------------------------