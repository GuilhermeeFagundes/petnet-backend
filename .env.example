# ─────────────────────────────────────────────
# Banco de Dados
# ─────────────────────────────────────────────
DATABASE_URL="mysql://root:${DB_PASSWORD}@localhost:5678/${DB_NAME}"

# Credenciais do MySQL (usadas pelo docker-compose.yml)
DB_ROOT_PASSWORD="senha-forte-do-root"
DB_NAME="netcao_development"
DB_USER="netcao"
DB_PASSWORD="senha-forte-do-usuario"

# ─────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# URL pública desta API — usada para montar links absolutos em e-mails
# (ex: o link de confirmação de agendamento aponta para API_BASE_URL/api/schedules/:id/confirm)
API_BASE_URL=http://localhost:3000

# ─────────────────────────────────────────────
# JWT - Autenticação
# OBRIGATÓRIO: mínimo de 32 caracteres
# Para gerar um segredo seguro, rode no terminal:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────
JWT_SECRET="seu-segredo-com-no-minimo-32-caracteres-mude-em-producao"
JWT_EXPIRES_IN="1d"

#-------------------------------------
# Configurações do Admin TI (Seed)
#-------------------------------------
ADMIN_CPF="00000000000"
ADMIN_NAME="Admin TI"
ADMIN_EMAIL="admin@petnet.com.br"
ADMIN_PASSWORD="MudarIssoEmProducao123"

#-------------------------------------
# Recuperação de senha
# https://resend.com
#-------------------------------------
RESEND_API_KEY=api-key-gerada-automaticamente
RESEND_FROM_EMAIL=nao-responda@petnet.com.br
FRONTEND_URL=http://localhost:5173
#-------------------------------------

# api-logs
LOG_API_URL=http://localhost:8080/logs #url-da-api
LOG_API_TOKEN=token-estatico
