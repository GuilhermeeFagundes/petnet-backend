// ------------------ AGENDAMENTO ------------------

model schedule {
  id               Int               @id @default(autoincrement())
  client_cpf       String            @db.Char(11)
  pet_id           Int
  collaborator_cpf String            @db.Char(11)
  date_time        DateTime          @db.DateTime(0)
  duration         schedule_duration @default(THIRTY_MIN)
  status           schedule_status   @default(SCHEDULED)
  observation      String?           @db.Text
  created_at       DateTime          @default(now()) @db.DateTime(0)

  client           user   @relation("client_schedules", fields: [client_cpf], references: [cpf], onDelete: NoAction, onUpdate: NoAction)
  pet              pet    @relation(fields: [pet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  collaborator     user   @relation("collaborator_schedules", fields: [collaborator_cpf], references: [cpf], onDelete: NoAction, onUpdate: NoAction)
  services         service[]

  @@index([client_cpf], map: "schedule_client_cpf_idx")
  @@index([pet_id], map: "schedule_pet_id_idx")
  @@index([collaborator_cpf], map: "schedule_collaborator_cpf_idx")
}

enum schedule_duration {
  THIRTY_MIN // 30m
  FORTY_FIVE_MIN // 45m
  ONE_HOUR // 1h
  ONE_HALF_HOUR // 1.5h
  TWO_HOURS // 2h
}

enum schedule_status {
  SCHEDULED
  CONFIRMED
  CANCELED
  FINISHED
}
